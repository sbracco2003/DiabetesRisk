      "source": [
        "Rather than relying on the default 0.5 cutoff, inspect precision-recall tradeoffs and define a helper function to choose thresholds by target recall."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "b1b0e809",
      "metadata": {
        "id": "b1b0e809"
      },
      "outputs": [],
      "source": [
        "from sklearn.metrics import precision_recall_curve\n",
        "\n",
        "precision, recall, thresholds = precision_recall_curve(y_test, proba)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "f2c34e98",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "f2c34e98",
        "outputId": "e7d4814b-1936-4965-803d-a33367571397"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Target recall: 0.2 (np.float64(0.24805771365149834), np.float64(0.20008952551477172), np.float64(0.6725071278102789))\n",
            "Target recall: 0.3 (np.float64(0.20857942182157288), np.float64(0.30035810205908686), np.float64(0.609160130732655))\n",
            "Target recall: 0.4 (np.float64(0.1871859296482412), np.float64(0.40017905102954343), np.float64(0.5601252830905002))\n"
          ]
        }
      ],
      "source": [
        "def threshold_for_recall(target_recall, precision, recall, thresholds):\n",
        "    # ignore last recall point (which corresponds to predicting everything positive)\n",
        "    valid = recall[:-1] >= target_recall\n",
        "\n",
        "    if not valid.any():\n",
        "        return None\n",
        "\n",
        "    idx = np.where(valid)[0][-1]  # last index meeting recall target\n",
        "    return precision[idx], recall[idx], thresholds[idx]\n",
        "\n",
        "for r in [0.20, 0.30, 0.40]:\n",
        "    result = threshold_for_recall(r, precision, recall, thresholds)\n",
        "    print(\"Target recall:\", r, result)"
      ]
    },
