      },
      "outputs": [],
      "source": [
        "!pip -q install shap\n",
        "import shap"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "6b61738b",
      "metadata": {
        "id": "6b61738b"
      },
      "outputs": [],
      "source": [
        "# fitted pieces from your pipeline\n",
        "pre = xgb_pipe.named_steps[\"preprocess\"]\n",
        "xgb_model = xgb_pipe.named_steps[\"model\"]\n",
        "\n",
        "# feature names after one-hot\n",
        "feature_names = pre.get_feature_names_out()\n",
        "\n",
        "# transform train/test\n",
        "X_train_t = pre.transform(X_train)\n",
        "X_test_t  = pre.transform(X_test)\n",
        "\n",
        "# Optional: if sparse, keep it sparse (good). For some plotting, dense is heavy."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "a844766b",
      "metadata": {
        "id": "a844766b"
      },
      "outputs": [],
      "source": [
        "# Random samples for background and explanation\n",
        "rng = np.random.default_rng(42)\n",
        "\n",
        "bg_idx = rng.choice(X_train_t.shape[0], size=min(200, X_train_t.shape[0]), replace=False)\n",
        "ex_idx = rng.choice(X_test_t.shape[0], size=min(500, X_test_t.shape[0]), replace=False)\n",
        "\n",
        "# Convert sparse → dense\n",
        "X_bg = X_train_t[bg_idx].toarray()\n",
        "X_ex = X_test_t[ex_idx].toarray()\n",
        "\n",
        "# Build explainer\n",
        "explainer = shap.TreeExplainer(xgb_model, data=X_bg)\n",
        "\n",
        "# Compute SHAP values\n",
        "shap_vals = explainer.shap_values(X_ex)\n",
        "\n",
        "# Binary models sometimes return list\n",
        "if isinstance(shap_vals, list):\n",
        "    shap_vals = shap_vals[1]"
      ]
    },
